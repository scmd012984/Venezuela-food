# Copia este archivo a `.env.local` y rellena los valores.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Email de contacto (opcional). Si lo dejas vacío se usa el valor por defecto del código.
NEXT_PUBLIC_CONTACT_EMAIL=

# WhatsApp: número en formato E.164 solo dígitos, con prefijo de país (sin + ni espacios).
# Ejemplo España: 34612345678
# Si lo dejas vacío, el botón "Por WhatsApp" abre el correo con un texto para pedir el número.
NEXT_PUBLIC_WHATSAPP_E164=
